 123:main.c        **** /* Function to check password */ 
 124:main.c        **** static void checkPassword() 
 125:main.c        **** { 
 126:main.c        ****     uint8_t correct = 1; 
 127:main.c        ****     for(int i = 0; i < PASSWORD_LENGTH; i++) 
 128:main.c        ****     { 
 129:main.c        ****         if(password_buffer[i] != PASSWORD[i]) 
 130:main.c        ****         { 
 131:main.c        ****             correct = 0; 
 132:main.c        ****             break; 
 133:main.c        ****         } 
 134:main.c        ****     } 
 135:main.c        ****      
 136:main.c        ****     if(correct) 
 137:main.c        ****     { 
 138:main.c        ****         SW_Tx_UART_PutString("Access allowed"); 
 139:main.c        ****         SW_Tx_UART_PutCRLF(); 
 140:main.c        ****         password_locked = 0; 
 141:main.c        ****         // ąæč¢ą╗ąĖą╣ čüą▓č¢čéą╗ąŠą┤č¢ąŠą┤ ą┐čĆąĖ čĆąŠąĘą▒ą╗ąŠą║čāą▓ą░ąĮąĮč¢ 

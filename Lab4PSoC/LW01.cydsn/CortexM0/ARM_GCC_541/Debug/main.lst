 143:main.c        ****         LED_G_Write(0); 
 144:main.c        ****         LED_B_Write(0); 
 145:main.c        ****         CyDelay(1000); 
 146:main.c        ****     } 
 147:main.c        ****     else 
 148:main.c        ****     { 
 149:main.c        ****         SW_Tx_UART_PutString("Access denied"); 
 150:main.c        ****         SW_Tx_UART_PutCRLF(); 
 151:main.c        ****         password_locked = 1; 
 152:main.c        ****     } 

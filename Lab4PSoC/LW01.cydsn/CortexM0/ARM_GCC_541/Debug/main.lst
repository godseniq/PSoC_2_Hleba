  36:main.c        ****  
  37:main.c        **** static void FourDigit74HC595_sendOneDigit(uint8_t position, uint8_t digit, 
  38:main.c        **** uint8_t dot)   
  39:main.c        **** {  
  40:main.c        ****     if(position >= 8)   // out of range, clear 7-segment display  
  41:main.c        ****     {  
  42:main.c        ****         FourDigit74HC595_sendData(0xFF);  
  43:main.c        ****         FourDigit74HC595_sendData(0xFF);  
  44:main.c        ****     }  
  45:main.c        ****     FourDigit74HC595_sendData(0xFF & ~(1 << position));      
  46:main.c        ****     if(dot) // if dot is needed  
  47:main.c        ****     {  
  48:main.c        ****         FourDigit74HC595_sendData(LED_NUM[digit] & 0x7F);  
  49:main.c        ****     }     else  
  50:main.c        ****     {  
  51:main.c        ****         FourDigit74HC595_sendData(LED_NUM[digit]);  
  52:main.c        ****     }  
  53:main.c        ****     Pin_Latch_Write(1); // Latch shift register  
  54:main.c        ****     Pin_Latch_Write(0);  
  55:main.c        **** }  
